---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="For Job Seekers" description="Career coaching and job search programs for international professionals.">
  <div class="page-hero">
    <div class="container">
      <span class="label" style="color: rgba(255,255,255,0.7);">For Job Seekers</span>
      <h1>Your Career, Your Path</h1>
      <p>Tailored support to help you break into or advance in the Danish job market.</p>
    </div>
  </div>

  <!-- Tab strip -->
  <div class="tab-strip">
    <div class="container">
      <div class="tab-nav">
        <button class="tab-btn" data-tab="workshops">🎓 Workshops</button>
        <button class="tab-btn active" data-tab="programs">📋 Personalized Job Search Programs</button>
        <button class="tab-btn" data-tab="consulting">🤝 1-1 Consulting</button>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">

      <!-- a. Workshops -->
      <div class="tab-panel hidden" id="panel-workshops">

        <div class="workshops-intro">
          <div class="workshops-intro-text">
            <h2>Workshops</h2>
            <p class="workshops-subtitle">Practical workshops for navigating the Danish job market</p>
            <p>These workshops are designed for internationals and professionals who want clearer direction, stronger applications, and a better understanding of how hiring works in Denmark.</p>
            <p>Each session is practical, focused, and tailored to real challenges job seekers face, from improving your CV and LinkedIn profile to networking, interviewing, and understanding Danish workplace culture.</p>
            <p>Whether you are just starting your search or trying to gain more traction, these workshops will help you approach the market with more clarity, confidence, and strategy.</p>
          </div>
          <div class="workshops-intro-cta">

            <!-- Video -->
            <div class="workshop-video-wrap">
              <video
                id="workshop-video"
                class="workshop-video"
                poster="/workshops_materials/video_thumbnail.webp"
                preload="none"
                controls
              >
                <source src="/workshops_materials/workshop_video.webm" type="video/webm" />
                <source src="/workshops_materials/workshop_video.mp4" type="video/mp4" />
              </video>
              <button class="video-play-btn" id="video-play-btn" aria-label="Play workshop video">
                <svg viewBox="0 0 24 24" fill="white" width="48" height="48"><circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.5)"/><polygon points="10,8 18,12 10,16" fill="white"/></svg>
              </button>
            </div>

            <!-- Scattered photos -->
            <div class="workshop-photos" id="workshop-photos">
              <div class="photo-item" style="--r:-14deg;--x:0%;--y:0%">
                <img src="/workshops_materials/1.jpeg" alt="Workshop photo 1" />
              </div>
              <div class="photo-item" style="--r:11deg;--x:15%;--y:5%">
                <img src="/workshops_materials/2.jpeg" alt="Workshop photo 2" />
              </div>
              <div class="photo-item" style="--r:-9deg;--x:-10%;--y:8%">
                <img src="/workshops_materials/3.jpeg" alt="Workshop photo 3" />
              </div>
              <div class="photo-item" style="--r:16deg;--x:8%;--y:-4%">
                <img src="/workshops_materials/4.jpeg" alt="Workshop photo 4" />
              </div>
              <div class="photo-item" style="--r:-18deg;--x:-5%;--y:3%">
                <img src="/workshops_materials/5.jpeg" alt="Workshop photo 5" />
              </div>
            </div>

            <!-- Lightbox -->
            <div class="photo-lightbox hidden" id="photo-lightbox">
              <button class="lightbox-close" id="lightbox-close" aria-label="Close">✕</button>
              <img src="" alt="" id="lightbox-img" />
            </div>

          </div>
        </div>

        <div class="workshops-grid">

          <div class="card workshop-card">
            <div class="workshop-icon">📄</div>
            <h3>CV for the Danish Job Market</h3>
            <p>Learn how to structure and tailor your CV for Danish employers. This workshop helps you present your experience clearly, highlight relevance, and create a stronger first impression.</p>
            <a href="/contact" class="btn btn-outline">Enquire Now</a>
          </div>

          <div class="card workshop-card">
            <div class="workshop-icon">💼</div>
            <h3>LinkedIn Profile Optimisation</h3>
            <p>
            
            Improve your LinkedIn profile so it communicates your value clearly and attracts the right opportunities. We cover your headline, summary, experience, and overall positioning.

            </p>

            <a href="/contact" class="btn btn-outline">Enquire Now</a>
          </div>

          <div class="card workshop-card">
            <div class="workshop-icon">🎯</div>
            <h3>Job Search Strategy & Targeting</h3>
            <p>
            Build a more focused and effective job search. Learn how to target the right roles, identify suitable companies, and approach the Danish market with more clarity and intention.
            </p>
            <a href="/contact" class="btn btn-outline">Enquire Now</a>
          </div>

          <div class="card workshop-card">
            <div class="workshop-icon">🤝</div>
            <h3>Networking in Denmark</h3>
            <p>
            Understand how networking works in the Danish job market. Learn how to reach out professionally, build genuine connections, and create opportunities through meaningful conversations.
            </p>
            <a href="/contact" class="btn btn-outline">Enquire Now</a>
          </div>

          <div class="card workshop-card">
            <div class="workshop-icon">🗣️</div>
            <h3>Interview Preparation and Confidence</h3>
            <p>
Prepare for interviews with more confidence and clarity. This workshop helps you structure strong answers, understand Danish interview expectations, and present yourself effectively.            </p>
            <a href="/contact" class="btn btn-outline">Enquire Now</a>
          </div>

          <div class="card workshop-card">
            <div class="workshop-icon">🌍</div>
            <h3>Understanding Danish Workplace Culture</h3>
            <p>
Get practical insight into Danish workplace culture, communication style, and expectations. A useful workshop for professionals who want to integrate and succeed in Denmark.            </p>
            <a href="/contact" class="btn btn-outline">Enquire Now</a>
          </div>

        </div>
      </div>

      <!-- b. Personalized Job Search Programs -->
      <div class="tab-panel" id="panel-programs">
        <div class="programs-grid">

          <div class="program-card card" tabindex="0">
            <div class="card-top">
              <span class="duration-badge">4-week</span>
              <h3>Essential Launch</h3>
              <p class="tagline">A strong foundation for your Danish job search.</p>
              <div class="program-price">1,499 DKK</div>
            </div>
            <div class="divider"></div>
            <p class="includes-title">What's included:</p>
            <ul class="include-list">
              <li>4 × 1-1 coaching sessions covering your profile, interests, and skills so you get a realistic picture of where you stand in the Danish job market and how to pitch yourself with confidence</li>
              <li>CV review and optimisation tailored for the Danish market</li>
              <li>LinkedIn profile enhancement for visibility and recruiter appeal</li>
              <li>A personalised cover letter template you can adapt for each application</li>
              <li>Weekly check-ins to keep you focused and on track</li>
              <li>Hands-on support with applications for 2 job roles you bring to us</li>
              <li>Email and call support throughout the program</li>
            </ul>
            <a href="/contact" class="btn btn-outline btn-full">Get Started</a>
          </div>

          <div class="program-card card card-featured" tabindex="0">
            <div class="featured-ribbon">Most Popular</div>
            <div class="card-top">
              <span class="duration-badge">6-week</span>
              <h3>Growth Accelerator</h3>
              <p class="tagline">A focused upgrade for your Danish job search.</p>
              <div class="program-price">2,499 DKK</div>
            </div>
            <div class="divider"></div>
            <p class="includes-title">What's included:</p>
            <p class="includes-prev">Everything from <strong>Essential Launch</strong>, plus:</p>
            <ul class="include-list">
              <li>6 × 1-1 coaching sessions, held weekly to keep your momentum going</li>
              <li>A personalised job search strategy with 3 matched roles researched for your profile, then hands-on support through the full application process</li>
              <li>Mock interview with tailored feedback whenever you get shortlisted</li>
              <li>Application review for multiple roles within the 6 weeks</li>
              <li>Continued email and text support between sessions</li>
            </ul>
            <a href="/contact" class="btn btn-outline btn-full">Get Started</a>
          </div>

          <div class="program-card card" tabindex="0">
            <div class="card-top">
              <span class="duration-badge">10-week</span>
              <h3>Full Transformation</h3>
              <p class="tagline">A full redesign of your Danish job search.</p>
              <div class="program-price">4,499 DKK</div>
            </div>
            <div class="divider"></div>
            <p class="includes-title">What's included:</p>
            <p class="includes-prev">Everything in the first <strong>2 packages</strong>, plus:</p>
            <ul class="include-list">
              <li>10 × 1-1 sessions covering strategy, mindset, interview preparation, and networking</li>
              <li>Full rewrite of your CV, LinkedIn, and multiple tailored cover letters</li>
              <li>Job market mapping to find the right roles and companies, with 5 matched positions researched and full application support included</li>
              <li>Multiple mock interviews with detailed, role-specific feedback each time</li>
              <li>3 coffee meetings with professionals from my industry network in Denmark</li>
              <li>Networking coaching covering LinkedIn outreach, how to approach people in Denmark, and building lasting professional relationships</li>
              <li>Danish workplace culture guidance on communication style, expectations, and day-to-day work norms</li>
              <li>Unlimited support between sessions by email and message</li>
              <li>Regular accountability check-ins to keep you moving forward</li>
            </ul>
            <a href="/contact" class="btn btn-outline btn-full">Get Started</a>
          </div>

        </div>
      </div>

      <!-- c. 1-1 Consulting -->
      <div class="tab-panel hidden" id="panel-consulting">
        <div class="consulting-grid">

          <div class="card consulting-card">
            <div class="consulting-top">
              <h3>Profile Review &amp; CV/LinkedIn/Portfolio Optimisation</h3>
              <span class="price-badge">300 DKK</span>
            </div>
            <ul class="include-list">
              <li>Detailed assessment of your skills, experience, interests, and transferable competencies</li>
              <li>Full CV rewrite and LinkedIn/Portfolio optimisation tailored for Danish employers and recruiters</li>
            </ul>
          </div>

          <div class="card consulting-card">
            <div class="consulting-top">
              <h3>Target Strategy &amp; Network Access</h3>
              <span class="price-badge">300 DKK</span>
            </div>
            <ul class="include-list">
              <li>Identify and approach 1–3 consulting firms that match your profile and career goals</li>
              <li>Craft strong unsolicited applications to your target companies</li>
              <li>Exposure through our recruiter and firm network in Denmark</li>
            </ul>
          </div>

          <div class="card consulting-card">
            <div class="consulting-top">
              <h3>Interview Preparation</h3>
              <span class="price-badge">300 DKK</span>
            </div>
            <ul class="include-list">
              <li>Mock interviews with personalised feedback after each session</li>
              <li>Covers both case and fit interview formats to help you perform at your best</li>
            </ul>
          </div>

        </div>

        <div class="bundle-card card">
          <span class="bundle-label">Bundle Offer</span>
          <p>Book <strong>Profile Review &amp; CV/LinkedIn Optimisation</strong> and <strong>Target Strategy &amp; Network Access</strong> together for just <strong>500 DKK</strong>.</p>
        </div>

      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container" style="text-align: center;">
      <h2>Ready to Take the Next Step?</h2>
      <p style="color: rgba(255,255,255,0.85); font-size: 1.125rem; margin: 1rem auto 2rem; max-width: 500px;">
        Let's build a plan to land your dream role in Denmark.
      </p>
      <a href="/contact" class="btn btn-white">Get Started</a>
    </div>
  </section>
</Layout>

<script is:inline>
  // Video play button
  var videoEl = document.getElementById('workshop-video');
  var playBtn = document.getElementById('video-play-btn');
  if (videoEl && playBtn) {
    playBtn.addEventListener('click', function() {
      playBtn.classList.add('hidden');
      videoEl.play();
    });
    videoEl.addEventListener('pause', function() {
      if (!videoEl.seeking && !videoEl.ended) {
        playBtn.classList.remove('hidden');
      }
    });
    videoEl.addEventListener('ended', function() {
      playBtn.classList.remove('hidden');
    });
    videoEl.addEventListener('play', function() {
      playBtn.classList.add('hidden');
    });
  }

  // Photo lightbox
  var lightbox = document.getElementById('photo-lightbox');
  var lightboxImg = document.getElementById('lightbox-img');
  var lightboxClose = document.getElementById('lightbox-close');
  function openLightbox(src, alt) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightboxImg.src = '';
    document.body.style.overflow = '';
  }
  document.querySelectorAll('.photo-item').forEach(function(item) {
    item.addEventListener('click', function() {
      openLightbox(this.querySelector('img').src, this.querySelector('img').alt);
    });
  });
  if (lightboxClose) {
    lightboxClose.addEventListener('click', closeLightbox);
  }
  if (lightbox) {
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeLightbox();
    });
  }

  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = this.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
      document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.add('hidden'); });
      this.classList.add('active');
      document.getElementById('panel-' + target).classList.remove('hidden');
    });
  });

  // Card focus on click
  document.querySelectorAll('.program-card').forEach(function(card) {
    card.addEventListener('click', function(e) {
      var grid = document.querySelector('.programs-grid');
      document.querySelectorAll('.program-card').forEach(function(c) { c.classList.remove('card-selected'); });
      this.classList.add('card-selected');
      grid.classList.add('has-selection');
      // Remove focus from whatever element was clicked inside the card
      if (document.activeElement) { document.activeElement.blur(); }
    });
  });
</script>

<style>
  /* ── Tab strip ── */
  .tab-strip {
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 4.5rem;
    z-index: 100;
    box-shadow: var(--shadow-sm);
  }

  .tab-nav {
    display: flex;
    gap: 0;
    justify-content: center;
  }

  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.75rem;
    font-size: 0.9375rem;
    font-weight: 600;
    font-family: var(--font-sans);
    cursor: pointer;
    border: none;
    background: transparent;
    color: var(--color-secondary);
    border-bottom: 3px solid transparent;
    transition: all 0.2s ease;
    margin-bottom: -1px;
  }

  .tab-btn:hover {
    color: var(--color-primary);
    background: var(--color-bg-soft);
  }

  .tab-btn.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
    background: transparent;
  }

  /* ── Panels ── */
  .hidden { display: none; }

  /* ── Empty / coming soon ── */
  .empty-state {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    padding: 3.5rem 2rem;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-icon { font-size: 2.5rem; display: block; margin-bottom: 1rem; }
  .empty-state h3 { margin-bottom: 0.75rem; }
  .empty-state p { color: var(--color-text-light); font-size: 0.9375rem; }
  .empty-state a { color: var(--color-accent); font-weight: 600; }

  /* ── Workshops intro ── */
  .workshops-intro {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  .workshops-intro-text h2 {
    margin-bottom: 0.5rem;
  }

  .workshops-subtitle {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
  }

  .workshops-intro-text p {
    color: var(--color-secondary);
    font-size: 0.9375rem;
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }

  .workshops-intro-cta {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Video ── */
  .workshop-video-wrap {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #000;
    aspect-ratio: 16/9;
  }

  .workshop-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .video-play-btn:hover {
    transform: scale(1.1);
  }

  .video-play-btn.hidden {
    display: none;
  }

  /* ── Scattered photos ── */
  .workshop-photos {
    position: relative;
    height: 220px;
  }

  .photo-item {
    position: absolute;
    width: 42%;
    cursor: pointer;
    border-radius: var(--radius-md);
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
    overflow: hidden;
    transform: rotate(var(--r)) translate(var(--x), var(--y));
    transition: transform 0.25s ease, box-shadow 0.25s ease, z-index 0s;
    z-index: 1;
  }

  .photo-item:nth-child(1) { left: 0%;   top: 10px; }
  .photo-item:nth-child(2) { left: 30%;  top: 0px;  }
  .photo-item:nth-child(3) { left: 60%;  top: 20px; }
  .photo-item:nth-child(4) { left: 5%;  top: 100px; }
  .photo-item:nth-child(5) { left: 50%;  top: 110px; }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 4/3;
  }

  .photo-item:hover {
    transform: rotate(0deg) translate(var(--x), var(--y)) scale(1.08);
    box-shadow: 0 8px 28px rgba(0,0,0,0.28);
    z-index: 10;
  }

  /* ── Lightbox ── */
  .photo-lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .photo-lightbox.hidden {
    display: none;
  }

  .photo-lightbox img {
    max-width: 90vw;
    max-height: 85vh;
    border-radius: var(--radius-lg);
    box-shadow: 0 16px 64px rgba(0,0,0,0.5);
    object-fit: contain;
  }

  .lightbox-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(255,255,255,0.15);
    border: none;
    color: white;
    font-size: 1.25rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .lightbox-close:hover {
    background: rgba(255,255,255,0.3);
  }

  .workshops-monthly-note {
    font-size: 0.875rem;
    color: var(--color-text-light);
    border-left: 3px solid var(--color-accent);
    padding-left: 0.75rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .workshops-intro {
      grid-template-columns: 1fr;
    }

    .workshops-intro-cta {
      position: static;
    }
  }

  /* ── Workshops grid ── */
  .workshops-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-items: stretch;
  }

  .workshop-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    height: 100%;
  }

  .workshop-icon {
    font-size: 2rem;
    line-height: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 3.5rem;
    height: 3.5rem;
    background: var(--color-accent-light);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .workshop-card h3 {
    font-size: 1.125rem;
    margin: 0;
  }

  .workshop-card p {
    color: var(--color-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }

  .workshop-card .btn {
    margin-top: auto;
    width: fit-content;
  }

  @media (max-width: 1024px) {
    .workshops-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .workshops-grid { grid-template-columns: 1fr; }
  }

  /* ── Programs grid ── */
  .programs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-items: stretch;
  }

  .program-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    cursor: pointer;
    outline: none;
    height: 100%;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .program-card.card-selected {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.25), var(--shadow-xl);
  }

  .card-featured {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.25), var(--shadow-xl);
  }

  .card-featured.card-selected {
    box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.25), var(--shadow-xl);
  }

  /* When another card is selected, unfocus the featured card */
  .programs-grid.has-selection .card-featured:not(.card-selected) {
    border-color: var(--color-border);
    box-shadow: var(--shadow-md);
  }

  /* Remove focus outline from Get Started buttons inside cards */
  .program-card .btn:focus {
    outline: none;
  }

  .featured-ribbon {
    position: absolute;
    top: -0.65rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 1rem;
    border-radius: 999px;
    white-space: nowrap;
    letter-spacing: 0.03em;
  }

  .card-top { display: flex; flex-direction: column; gap: 0.5rem; }

  .duration-badge {
    display: inline-block;
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-size: 0.8125rem;
    font-weight: 700;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
    width: fit-content;
  }

  .program-card h3 { font-size: 1.25rem; margin: 0; }

  .program-price {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-accent);
    margin-top: 0.25rem;
