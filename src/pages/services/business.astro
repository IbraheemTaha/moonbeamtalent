---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="For Businesses" description="End-to-end talent search and RPO services for startups and scale-ups.">
  <div class="page-hero">
    <div class="container">
      <span class="label" style="color: rgba(255,255,255,0.7);">For Businesses</span>
      <h1>Recruitment Solutions</h1>
      <p>Customized recruitment support, built around your needs.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="intro-text">
        <p>Whether you need one key hire or a dedicated partner to scale your team, Moonbeam offers flexible recruitment solutions tailored to your business goals.</p>
      </div>
    </div>
  </section>

  <!-- End-to-End Talent Search -->
  <section class="section-alt">
    <div class="container">
      <div class="offering-grid">
        <div class="offering-content">
          <span class="label">Service 1</span>
          <h2>End to End Talent Search</h2>

          <h4>What's included:</h4>
          <div class="features-list">
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>A complete recruitment solution designed to deliver the right hire through a structured, transparent, and high-quality process.</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Full talent search: from sourcing to shortlist and hire</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>End-to-end ownership of the process, working as your strategic partner</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Interview templates and scorecards to support hiring managers</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Diversity-focused sourcing (optional)</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Interview scheduling, coordination, and stakeholder management</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Offer negotiation and candidate engagement through to start date</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Continuous shortlists until the position is successfully filled</span>
            </div>
          </div>
        </div>

        <div class="pricing-card card">
          <span class="label">Pricing</span>
          <div class="price">50,000–60,000 DKK</div>
          <p class="price-note">depending on role level</p>

          <div class="price-breakdown">
            <div class="price-row">
              <span>Upfront</span>
              <strong>25%</strong>
            </div>
            <div class="price-row">
              <span>Upon hire</span>
              <strong>75%</strong>
            </div>
          </div>

          <div class="price-addon">
            <h4>Additional Service</h4>
            <p>Structured Interview Templates &amp; Scorecards</p>
            <strong>5,000 DKK</strong>
            <p class="addon-note">Designed to reduce bias, empower hiring managers, and ensure a consistent, inclusive candidate experience.</p>
          </div>

          <a href="/#contact" class="btn btn-primary" style="width: 100%;">Get Started</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Talent RPO -->
  <section class="section">
    <div class="container">
      <div class="offering-grid reverse">
        <div class="pricing-card card">
          <span class="label">Pricing</span>
          <div class="price">From 50,000 DKK</div>
          <p class="price-note">per month (3–6 month engagement)</p>

          <div class="price-breakdown">
            <div class="price-row">
              <span>Model</span>
              <strong>Monthly</strong>
            </div>
            <div class="price-row">
              <span>Hires</span>
              <strong>Unlimited</strong>
            </div>
          </div>

          <p class="price-note">Pricing is based on the number of roles, seniority levels, and scope of support.</p>

          <a href="/#contact" class="btn btn-primary" style="width: 100%;">Get Started</a>
        </div>

        <div class="offering-content">
          <span class="label">Service 2</span>
          <h2>Talent RPO</h2>
          <p class="offering-intro">
            Talent RPO (Recruitment Process Outsourcing) — A flexible, in-house recruitment partnership designed for startups and scale-ups that are growing fast and need consistent, high-quality hiring support.
          </p>

          <h4>What's included:</h4>
          <div class="features-list">
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Ideal for companies scaling or hiring across multiple roles</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>I work as part of your internal team, fully embedded in your culture and processes</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>End-to-end recruitment ownership: from manpower planning to onboarding</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Continuous collaboration with founders and hiring managers</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Full recruitment support across tech, product, and commercial functions</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Unlimited hires within the agreed engagement period</span>
            </div>
          </div>

          <h4>Why choose Talent RPO:</h4>
          <div class="features-list">
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Seamless extension of your team with dedicated recruitment expertise</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Scalable and cost-effective alternative to agency hiring</span>
            </div>
            <div class="feature-item">
              <span class="feature-check">✓</span>
              <span>Ensures process consistency, candidate quality, and faster time-to-hire</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container" style="text-align: center;">
      <h2>Ready to Scale Your Team?</h2>
      <p style="color: rgba(255,255,255,0.85); font-size: 1.25rem; margin: 1rem auto 2rem; max-width: 500px;">
        Let's find the right model for your hiring needs.
      </p>
      <a href="/#contact" class="btn btn-white">Start Hiring</a>
    </div>
  </section>
</Layout>

<style>
  .intro-text {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    font-size: 1.125rem;
    color: var(--color-secondary);
  }

  .offering-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .offering-grid.reverse {
    grid-template-columns: 1fr 1.2fr;
  }

  .offering-content h2 {
    margin-bottom: 1rem;
  }

  .offering-content h4 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1rem;
    color: var(--color-primary);
  }

  .offering-intro {
    color: var(--color-secondary);
    font-size: 1.0625rem;
    margin-bottom: 1rem;
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--color-secondary);
  }

  .feature-check {
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .pricing-card {
    padding: 2.5rem;
    text-align: center;
    background: var(--color-white);
    position: sticky;
    top: 6rem;
  }

  .price {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0.5rem 0;
  }

  .price-note {
    color: var(--color-text-light);
    font-size: 0.9375rem;
    margin-bottom: 1.5rem;
  }

  .price-breakdown {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
    margin-bottom: 1.5rem;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    padding: 0.375rem 0;
    font-size: 0.9375rem;
    color: var(--color-secondary);
  }

  .price-addon {
    background: var(--color-bg-soft);
    border-radius: var(--radius-md);
    padding: 1rem;
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .price-addon h4 {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .price-addon p {
    font-size: 0.875rem;
    color: var(--color-secondary);
    margin-bottom: 0.25rem;
  }

  .addon-note {
    font-size: 0.8125rem !important;
    color: var(--color-text-light) !important;
    margin-top: 0.5rem;
  }

  .cta-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0e7490 100%);
    color: white;
  }

  .cta-section h2 {
    color: white;
  }

  @media (max-width: 768px) {
    .offering-grid,
    .offering-grid.reverse {
      grid-template-columns: 1fr;
    }

    .pricing-card {
      position: static;
    }
  }
</style>
