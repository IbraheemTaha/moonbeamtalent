---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Services" description="IT Recruitment, Onboarding Support, and Career Coaching services by Moonbeam Talent.">
  <div class="page-hero">
    <div class="container">
      <span class="label" style="color: rgba(255,255,255,0.7);">Our Services</span>
      <h1>Helping Companies Hire & Professionals Grow</h1>
      <p>Whether you are building a team or planning your next move, the support is tailored to your goals.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="services-grid">
        <div class="service-detail card">
          <div class="service-icon-lg">🔍</div>
          <h3>Recruitment</h3>
          <ul class="service-bullets">
            <li>Strategic recruitment support for startups, scale-ups, and growing teams</li>
            <li>End-to-end search support across tech, product, commercial, and leadership roles</li>
            <li>Targeted sourcing and personalised outreach to reach the right talent</li>
            <li>Structured, transparent processes that support better hiring decisions</li>
            <li>Flexible recruitment solutions for one-off hires or ongoing growth support</li>
            <li>Focused on quality hires, strong candidate experience, and long-term business impact</li>
          </ul>
          <p class="card-cta-text">Find the right people to help your business grow.</p>
          <a href="/services/business" class="btn btn-outline">Start Hiring →</a>
        </div>

        <div class="service-detail card">
          <div class="service-icon-lg">🎯</div>
          <h3>Career Consulting</h3>
          <ul class="service-bullets">

            <li>Personalised career support for professionals navigating the Danish job market</li>
            <li>Hands-on help with CV and LinkedIn optimisation to improve clarity and impact</li>
            <li>Interview preparation tailored to Danish hiring expectations</li>
            <li>Guidance on targeted outreach, positioning, and job search strategy</li>
            <li>Support in presenting your experience, strengths, and transferable skills clearly</li>
            <li>Designed to help internationals build confidence and move forward with direction</li>

          </ul>
          <p class="card-cta-text">Take the next step in your career with clarity and confidence.</p>
          <a href="/services/talent" class="btn btn-outline">Advance Your Career →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section (Casis-inspired) -->
  <section class="section-alt">
    <div class="container">
      <div class="section-header">
        <span class="label">How We Work</span>
        <h2>Our Recruitment Process</h2>
        <p>A structured approach that ensures quality at every stage.</p>
      </div>

      <div class="process-steps">
        <div class="step">
          <div class="step-number">01</div>
          <h3>Calibrate</h3>
          <p>We deeply understand your needs, culture, and what makes a great fit for your team.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-number">02</div>
          <h3>Source</h3>
          <p>Targeted sourcing across multiple channels with a focus on diversity and quality.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-number">03</div>
          <h3>Screen</h3>
          <p>Thorough assessment of technical skills, cultural fit, and motivation.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-number">04</div>
          <h3>Hired</h3>
          <p>Offer negotiation, onboarding support, and continuous follow-up.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container" style="text-align: center;">
      <h2>Ready to Build Your Team?</h2>
      <p style="color: rgba(255,255,255,0.85); font-size: 1.25rem; margin: 1rem auto 2rem; max-width: 500px;">
        Let's discuss how Moonbeam Talent can help you find the right people.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/services/business" class="btn btn-outline" style="color: white; border-color: white;">For Business</a>
        <a href="/services/talent" class="btn btn-outline" style="color: white; border-color: white;">For Job Seekers</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 860px;
    margin: 0 auto;
  }

  .service-detail {
    padding: 2.5rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
  }

  .service-detail .btn {
    margin-top: auto;
    align-self: center;
  }

  .service-icon-lg {
    font-size: 2.5rem;
    margin-bottom: 1.25rem;
  }

  .service-detail h3 {
    margin-bottom: 1rem;
  }

  .service-detail p {
    color: var(--color-secondary);
    margin-bottom: 1.25rem;
    font-size: 0.9375rem;
  }

  .service-bullets {
    list-style: none;
    text-align: left;
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-bullets li {
    color: var(--color-secondary);
    font-size: 0.9375rem;
    padding-left: 1.25rem;
    position: relative;
  }

  .service-bullets li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  .card-cta-text {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  /* Process Steps */
  .process-steps {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
  }

  .step {
    text-align: center;
    flex: 1;
    max-width: 220px;
    padding: 0 1rem;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dark));
    color: white;
    font-size: 1.25rem;
    font-weight: 800;
    margin-bottom: 1.25rem;
  }

  .step h3 {
    margin-bottom: 0.5rem;
  }

  .step p {
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  .step-connector {
    width: 60px;
    height: 2px;
    background: var(--color-border);
    margin-top: 30px;
    flex-shrink: 0;
  }

  /* CTA Section */
  .cta-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0e7490 100%);
    color: white;
  }

  .cta-section h2 {
    color: white;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
    }
  }

  @media (max-width: 768px) {
    .process-steps {
      flex-direction: column;
      align-items: center;
    }

    .step-connector {
      width: 2px;
      height: 40px;
      margin: 0;
    }
  }
</style>
