---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedServices from '../components/FeaturedServices.astro';
import AboutPreview from '../components/AboutPreview.astro';
import CompanyLogos from '../components/CompanyLogos.astro';
import TestimonialsPreview from '../components/TestimonialsPreview.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Home">
  <Hero
    title="3,000+ hires. Global reach. Deeply personal recruitment."
    subtitle="Build diverse, high-performing teams across the Nordics and Europe-wide."
    cta="Let's talk"
    ctaLink="#contact"
    showMetrics={true}
  />
  <FeaturedServices />
  <AboutPreview />
  <CompanyLogos />
  <TestimonialsPreview />
  <ContactForm />
</Layout>
