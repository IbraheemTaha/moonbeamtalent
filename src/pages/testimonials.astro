---
import Layout from '../layouts/Layout.astro';
import { testimonials } from '../data/testimonials';

const business = [...testimonials]
  .filter(t => t.type === 'business')
  .sort((a, b) => a.text.length - b.text.length);

const talent = [...testimonials]
  .filter(t => t.type === 'talent')
  .sort((a, b) => a.text.length - b.text.length);

const bCol1 = business.filter((_, i) => i % 2 === 0);
const bCol2 = business.filter((_, i) => i % 2 === 1);
const tCol1 = talent.filter((_, i) => i % 2 === 0);
const tCol2 = talent.filter((_, i) => i % 2 === 1);
---

<Layout title="Testimonials" description="What people say about working with Nivedita Mishra and Moonbeam Talent.">
  <div class="page-hero">
    <div class="container">
      <span class="label" style="color: rgba(255,255,255,0.7);">Testimonials</span>
      <h1>What People Say</h1>
      <p>Hear from the hiring managers and professionals Nivedita has worked with.</p>
    </div>
  </div>

  <!-- Testimonial navigation -->
  <nav class="testimonial-nav-wrap" aria-label="Testimonial categories">
    <div class="container">
      <div class="testimonial-nav">
        <a class="testimonial-nav-link active" href="#business-stories" data-testimonial-link aria-current="true">
          <span class="testimonial-nav-text">
            <strong>
              <span class="nav-title-full">💼 Trusted by Businesses</span>
              <span class="nav-title-short">Businesses</span>
            </strong>
            <small>{business.length} hiring partner stories</small>
          </span>
        </a>
        <a class="testimonial-nav-link" href="#talent-stories" data-testimonial-link>
          <span class="testimonial-nav-text">
            <strong>
              <span class="nav-title-full">🎯 Talent Stories</span>
              <span class="nav-title-short">Talent</span>
            </strong>
            <small>{talent.length} job seeker stories</small>
          </span>
        </a>
      </div>
    </div>
  </nav>

  <section class="section testimonials-section">
    <div class="container testimonials-stack">

      <!-- Business stories -->
      <div class="testimonial-panel" id="business-stories" data-testimonial-section>
        <div class="section-header testimonial-section-header">
          <span class="label">💼 Trusted by Businesses</span>
          <h2>Recruitment partnerships built on clarity, care, and strong hires.</h2>
          <p>Hiring managers, founders, and people teams share what it is like to work with Nivedita.</p>
        </div>

        <div class="masonry-grid">
          <div class="masonry-col">
            {bCol1.map((t) => (
              <div class="testimonial-card card">
                <p class="testimonial-text">{t.text}</p>
                <div class="testimonial-author">
                  <div class="author-avatar">{t.name.split(' ').map((n: string) => n[0]).join('')}</div>
                  <div>
                    <div class="author-name">{t.name}</div>
                    <div class="author-role">{t.role} · {t.company}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="masonry-col">
            {bCol2.map((t) => (
              <div class="testimonial-card card">
                <p class="testimonial-text">{t.text}</p>
                <div class="testimonial-author">
                  <div class="author-avatar">{t.name.split(' ').map((n: string) => n[0]).join('')}</div>
                  <div>
                    <div class="author-name">{t.name}</div>
                    <div class="author-role">{t.role} · {t.company}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Talent stories -->
      <div class="testimonial-panel" id="talent-stories" data-testimonial-section>
        <div class="section-header testimonial-section-header">
          <span class="label">🎯 Talent Stories</span>
          <h2>Practical career support that helps professionals move forward.</h2>
          <p>Job seekers share the feedback, confidence, and direction they took from Moonbeam Talent.</p>
        </div>

        {talent.length === 0 ? (
          <div class="empty-state">
            <span class="empty-icon">🎯</span>
            <p>Testimonials from job seekers coming soon.</p>
          </div>
        ) : (
          <div class="masonry-grid">
            <div class="masonry-col">
              {tCol1.map((t) => (
                <div class="testimonial-card card">
                  {t.category && <span class="testimonial-category">{t.category} Testimonial</span>}

                  <p class="testimonial-text">{t.text}</p>
                  <div class="testimonial-author">
                    <div class="author-avatar">{t.name.split(' ').map((n: string) => n[0]).join('')}</div>
                    <div>
                      <div class="author-name">{t.name}</div>
                      <div class="author-role">{t.role} · {t.company}</div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <div class="masonry-col">
              {tCol2.map((t) => (
                <div class="testimonial-card card">
                  {t.category && <span class="testimonial-category">{t.category} Testimonial</span>}

                  <p class="testimonial-text">{t.text}</p>
                  <div class="testimonial-author">
                    <div class="author-avatar">{t.name.split(' ').map((n: string) => n[0]).join('')}</div>
                    <div>
                      <div class="author-name">{t.name}</div>
                      <div class="author-role">{t.role} · {t.company}</div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

    </div>
  </section>
</Layout>

<script is:inline>
  const testimonialLinks = Array.from(document.querySelectorAll('[data-testimonial-link]'));
  const testimonialSections = Array.from(document.querySelectorAll('[data-testimonial-section]'));

  function setActiveTestimonialSection(id) {
    testimonialLinks.forEach((link) => {
      const isActive = link.getAttribute('href') === '#' + id;
      link.classList.toggle('active', isActive);

      if (isActive) {
        link.setAttribute('aria-current', 'true');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  testimonialLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      const targetId = link.getAttribute('href')?.slice(1);
      const target = targetId ? document.getElementById(targetId) : null;

      if (!target) return;

      event.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      history.replaceState(null, '', '#' + targetId);
      setActiveTestimonialSection(targetId);
    });
  });

  const testimonialObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        setActiveTestimonialSection(entry.target.id);
      }
    });
  }, {
    rootMargin: '-45% 0px -45% 0px',
    threshold: 0,
  });

  testimonialSections.forEach((section) => testimonialObserver.observe(section));
</script>

<style>
  /* ── Testimonial navigation ── */
  .testimonial-nav-wrap {
    background: rgba(255, 255, 255, 0.97);
    border-bottom: 1px solid rgba(226, 232, 240, 0.9);
    position: sticky;
    top: 4.5rem;
    z-index: 100;
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(12px);
  }

  .testimonial-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(220px, 300px));
    gap: 0.75rem;
    justify-content: center;
    overflow-x: auto;
    padding: 0.75rem 0;
    scroll-snap-type: x proximity;
    scrollbar-width: thin;
  }

  .testimonial-nav-link {
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    padding: 0.85rem 1rem;
    color: var(--color-secondary);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
    text-decoration: none;
    scroll-snap-align: start;
    transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .testimonial-nav-link:hover,
  .testimonial-nav-link.active {
    color: var(--color-primary);
    background: var(--color-bg-soft);
    border-color: rgba(8, 145, 178, 0.45);
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
    transform: translateY(-1px);
  }

  .testimonial-nav-text {
    display: flex;
    align-items: center;
    min-width: 0;
    flex-direction: column;
    gap: 0.2rem;
    line-height: 1.25;
  }

  .testimonial-nav-text strong {
    color: inherit;
    font-size: 0.9375rem;
  }

  .testimonial-nav-text small {
    color: var(--color-text-light);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .nav-title-short {
    display: none;
  }

  .testimonials-section {
    background: linear-gradient(180deg, var(--color-white) 0%, var(--color-bg-soft) 52%, var(--color-white) 100%);
  }

  .testimonials-stack {
    display: flex;
    flex-direction: column;
    gap: 7rem;
  }

  .testimonial-panel {
    scroll-margin-top: 11.5rem;
  }

  .testimonial-section-header {
    max-width: 760px;
  }

  .testimonial-section-header h2 {
    margin-bottom: 0;
  }

  /* ── Masonry grid ── */
  .masonry-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
    align-items: start;
  }

  .masonry-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    min-width: 0;
  }

  /* ── Category label ── */
  .testimonial-category {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-accent-light);
    width: 100%;
  }

  .testimonial-category::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  /* ── Card ── */
  .testimonial-card {
    padding: 2rem;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

.testimonial-text {
    color: var(--color-secondary);
    font-size: 0.9375rem;
    line-height: 1.8;
    white-space: pre-line;
    overflow-wrap: break-word;
    word-break: break-word;
    flex: 1;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dark));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .author-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-primary);
  }

  .author-role {
    font-size: 0.8125rem;
    color: var(--color-text-light);
  }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 5rem 0;
    color: var(--color-text-light);
  }

  .empty-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .masonry-grid { grid-template-columns: 1fr; }

    .testimonial-nav {
      margin-right: -1.5rem;
      padding-right: 1.5rem;
    }

    .testimonial-nav-link {
      min-width: min(84vw, 340px);
    }

    .testimonials-stack {
      gap: 5rem;
    }
  }

  @media (max-width: 640px) {
    .testimonial-nav-wrap {
      box-shadow: 0 4px 14px rgba(15, 23, 42, 0.08);
    }

    .testimonial-nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.35rem;
      margin-right: 0;
      overflow-x: visible;
      padding: 0.5rem 0;
      scroll-snap-type: none;
    }

    .testimonial-nav-text small {
      display: none;
    }

    .nav-title-full {
      display: none;
    }

    .nav-title-short {
      display: inline;
    }

    .testimonial-nav-link {
      min-width: 0;
      justify-content: center;
      padding: 0.65rem 0.25rem;
      border-radius: var(--radius-sm);
      box-shadow: none;
      text-align: center;
      transform: none;
    }

    .testimonial-nav-link:hover,
    .testimonial-nav-link.active {
      box-shadow: none;
      transform: none;
    }

    .testimonial-nav-text strong {
      font-size: 0.82rem;
      line-height: 1.15;
    }

    .testimonial-panel {
      scroll-margin-top: 8.75rem;
    }
  }
</style>
