---
const services = [
  {
    icon: "💼",
    title: "For Businesses",
    description: "Customized recruitment support, built around your needs.",
    link: "/services/business",
  },
  {
    icon: "💡",
    title: "For Professionals",
    description: "Empowering internationals navigating the Danish job market.",
    link: "/services/talent",
  },
];
---

<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="label">What We Do</span>
      <h2>Recruitment That Puts People First</h2>
      <p>Whether you're scaling your team or seeking your next opportunity, Moonbeam Talent is here to guide the way.</p>
    </div>

    <div class="services-row">
      {services.map((s) => (
        <a href={s.link} class="service-card card">
          <div class="service-icon">{s.icon}</div>
          <h3>{s.title}</h3>
          <p>{s.description}</p>
          <span class="service-arrow">Learn more →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .service-card {
    text-decoration: none;
    text-align: center;
    padding: 3rem 2rem;
  }

  .service-icon {
    font-size: 3rem;
    margin-bottom: 1.25rem;
  }

  .service-card h3 {
    margin-bottom: 0.75rem;
  }

  .service-card p {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
  }

  .service-arrow {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .service-card:hover .service-arrow {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .services-row {
      grid-template-columns: 1fr;
    }
  }
</style>
