---
import { site } from '../data/site';
---

<section class="section-alt" id="contact">
  <div class="container">
    <div class="section-header">
      <span class="label">Get in Touch</span>
      <h2>Let's Talk About Your Hiring Needs</h2>
      <p>Whether you're a business seeking top talent or a professional navigating the job market, we're here to help.</p>
    </div>

    <div class="contact-grid">
      <form class="contact-form" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value={site.web3formsKey} />

        <div class="form-row">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required placeholder="Your name" />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="you@example.com" />
          </div>
        </div>

        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" required placeholder="How can we help?" />
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required placeholder="Tell us about your needs..."></textarea>
        </div>

        <div class="form-check">
          <input type="checkbox" id="privacy" name="privacy" required />
          <label for="privacy">
            I agree to the <a href="/privacy-policy">Privacy Policy</a>
          </label>
        </div>

        <button type="submit" class="btn btn-primary">Send Message</button>
      </form>

      {/* <div class="contact-info">
        <div class="info-card">
          <div class="info-icon">📧</div>
          <div class="info-body">
            <h4>Email</h4>
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </div>
        </div>
        <div class="info-card">
          <div class="info-icon">📞</div>
          <div class="info-body">
            <h4>Phone</h4>
            <a href={`tel:${site.phone.replace(/\s/g, '')}`}>{site.phone}</a>
          </div>
        </div>
        <div class="info-card">
          <div class="info-icon">📍</div>
          <div class="info-body">
            <h4>Address</h4>
            <p>{site.address}</p>
          </div>
        </div>
        <div class="info-card">
          <div class="info-icon">💼</div>
          <div class="info-body">
            <h4>LinkedIn</h4>
            <a href={site.linkedin} target="_blank" rel="noopener noreferrer">Connect with Nivedita</a>
          </div>
        </div>
      </div> */}
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    max-width: 700px;
    margin: 0 auto;
  }

  /* When contact-info is present, use two-column side-by-side layout */
  .contact-grid:has(.contact-info) {
    max-width: 1000px;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-form {
    background: var(--color-white);
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.375rem;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-family: var(--font-sans);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
    color: var(--color-text);
    transition: all 0.2s ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.1);
    background: var(--color-white);
  }

  .form-group textarea {
    resize: vertical;
  }

  .form-check {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  .form-check a {
    text-decoration: underline;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .info-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-white);
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .info-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .info-body h4 {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 0.15rem;
  }

  .info-body a,
  .info-body p {
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
