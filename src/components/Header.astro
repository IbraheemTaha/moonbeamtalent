---
const currentPath = Astro.url.pathname;

const navItems = [
  { name: "Home", url: "/" },
  {
    name: "Services",
    url: "/services",
    children: [
      { name: "All Services", url: "/services", divider: true },
      { name: "For Business", url: "/services/business" },
      { name: "For Job Seekers", url: "/services/talent" },
    ],
  },
  { name: "Open Positions", url: "/openings" },
  { name: "Testimonials", url: "/testimonials" },
  {
    name: "About",
    url: "/about",
    children: [
      { name: "Who am I?", url: "/about#about-nivedita-mishra" },
      { name: "The story behind", url: "/about#the-story-behind-moonbeam" },
      { name: "Why Moonbeam?", url: "/about#why-moonbeam" },
    ],
  },
  { name: "Contact", url: "/contact" },
];
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <div class="logo-banner">
        <img src="/img/logos/moonbeam-light.svg" alt="Moonbeam Talent" class="logo-img" />
      </div>
    </a>

    <button class="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="nav" role="navigation">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class={`nav-item ${item.children ? 'has-dropdown' : ''}`}>
            <a
              href={item.url}
              class={`nav-link ${item.url === '/' ? currentPath === '/' ? 'active' : '' : currentPath.startsWith(item.url) ? 'active' : ''}`}
            >
              {item.name}
              {item.children && (
                <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </a>
            {item.children && (
              <ul class="dropdown">
                {item.children.map((child) => (
                  <li class={child.divider ? 'has-divider' : ''}>
                    <a href={child.url} class="dropdown-link">{child.name}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.mobile-toggle');
  const nav = document.querySelector('.nav');
  const header = document.querySelector('.header');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('open');
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
    border-bottom: 1px solid transparent;
  }

  .header.scrolled {
    border-bottom-color: rgba(255, 255, 255, 0.1);
    box-shadow: var(--shadow-sm);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-banner {
    position: relative;
    isolation: isolate;
    background: var(--color-primary);
    border-radius: 12px;
    padding: 0.4rem 1.1rem;
    display: flex;
    align-items: center;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07), 0 4px 20px rgba(0, 0, 0, 0.3);
    transition: all 0.4s ease;
  }

  .logo-banner::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 13px;
    background: linear-gradient(315deg, rgba(103, 232, 249, 0.55) 0%, rgba(8, 145, 178, 0.1) 55%, rgba(103, 232, 249, 0.08) 100%);
    z-index: -1;
    transition: all 0.4s ease;
  }

  .logo:hover .logo-banner {
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 4px 16px rgba(8, 145, 178, 0.16);
  }

  .logo:hover .logo-banner::before {
    background: rgba(8, 145, 178, 0.22);
  }

  .logo-img {
    height: 34px;
    width: auto;
    display: block;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 1rem;
    color: var(--color-secondary);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-primary);
    background: var(--color-accent-light);
    box-shadow: inset 0 -2px 0 var(--color-accent);
  }

  .nav-link.active {
    color: var(--color-primary);
    background: var(--color-accent-light);
    box-shadow: inset 0 -3px 0 var(--color-accent);
    font-weight: 700;
  }

  .dropdown-arrow {
    transition: transform 0.2s ease;
  }

  .has-dropdown:hover .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 200px;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    padding: 0.5rem;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: all 0.2s ease;
  }

  .has-dropdown:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-link {
    display: block;
    padding: 0.625rem 1rem;
    color: var(--color-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition: all 0.15s ease;
  }

  .dropdown-link:hover {
    color: var(--color-accent);
    background: var(--color-bg-soft);
  }

  .has-divider {
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.35rem;
    padding-bottom: 0.35rem;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .mobile-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-primary);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  @media (max-width: 768px) {
    .mobile-toggle {
      display: flex;
    }

    .nav {
      display: none;
      position: fixed;
      top: 4.5rem;
      left: 0;
      right: 0;
      background: var(--color-white);
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow-lg);
      padding: 1rem;
    }

    .nav.open {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      align-items: stretch;
    }

    .dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border: none;
      padding-left: 1rem;
    }
  }
</style>
